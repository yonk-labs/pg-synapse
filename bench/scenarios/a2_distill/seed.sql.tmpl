-- a2_distill seed: feedback schema with 8 mixed-sentiment customer comments.
-- Deterministic, no randomness.

CREATE SCHEMA IF NOT EXISTS feedback;

CREATE TABLE IF NOT EXISTS feedback.items (
    id   INT PRIMARY KEY,
    body TEXT NOT NULL
);

CREATE TABLE IF NOT EXISTS feedback.digest (
    id        INT PRIMARY KEY,
    sentiment TEXT NOT NULL,
    gist      TEXT NOT NULL
);

TRUNCATE feedback.items;
TRUNCATE feedback.digest;

